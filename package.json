{
  "name": "docgen-ai",
  "version": "0.1.0",
  "description": "AI-powered codebase documentation generator. Analyzes repos via AST parsing and generates architecture docs, API references, module guides, and onboarding material.",
  "author": "docgen",
  "license": "MIT",
  "homepage": "https://github.com/docgen/docgen",
  "repository": {
    "type": "git",
    "url": "https://github.com/docgen/docgen.git"
  },
  "bugs": {
    "url": "https://github.com/docgen/docgen/issues"
  },
  "keywords": [
    "documentation",
    "docs",
    "codegen",
    "ast",
    "code-analysis",
    "api-docs",
    "readme",
    "architecture",
    "ai",
    "anthropic",
    "tree-sitter",
    "typescript",
    "python",
    "express",
    "fastapi",
    "developer-tools",
    "cli"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "docgen": "dist/cli/commands.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "jest --forceExit",
    "test:verbose": "jest --verbose --forceExit",
    "test:coverage": "jest --coverage --forceExit",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist/",
    "prebuild": "npm run clean",
    "prepublishOnly": "npm run lint && npm run build && npm test",
    "postpublish": "echo '✅ Published to npm'",
    "dev": "ts-node src/cli/commands.ts",
    "start": "node dist/cli/commands.js"
  },
  "dependencies": {
    "@babel/parser": "^7.24.0",
    "@babel/traverse": "^7.24.0",
    "@babel/types": "^7.24.0",
    "commander": "^12.0.0",
    "express": "^4.19.0",
    "marked": "^12.0.0",
    "tree-sitter-python": "^0.25.0",
    "web-tree-sitter": "^0.26.7"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  }
}
